{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug GrayScaleMorph",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/GrayScaleMorph",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "Release GrayScaleMorph",
